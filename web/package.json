{
  "name": "proxy-broker-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 38181 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 38183 --strictPort",
    "check": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:stories": "bun ./scripts/verify-stories.ts",
    "storybook": "storybook dev -p 38182 --host 127.0.0.1 --no-open",
    "storybook:ci": "storybook dev -p 38182 --host 127.0.0.1 --ci --disable-telemetry --no-open",
    "build-storybook": "storybook build",
    "test-storybook": "bun ./scripts/run-storybook-tests.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource/fira-code": "^5.2.7",
